# Trade Way CRM — production environment template.
# Copy to .env.prod (in repo root) and fill in. Never commit .env.prod.
#
# Generate strong secrets with:
#   openssl rand -hex 32   # for JWT_ACCESS_SECRET / JWT_REFRESH_SECRET
#   openssl rand -base64 24 | tr -d '+/=' | head -c 24   # for passwords

# ── Postgres ────────────────────────────────────────────────────────────
POSTGRES_DB=crm_tradeway
POSTGRES_USER=crm_user
POSTGRES_PASSWORD=CHANGE_ME_postgres_strong_password

# ── Redis ───────────────────────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME_redis_strong_password

# ── API auth (must each be ≥ 32 chars and different from each other) ──
JWT_ACCESS_SECRET=CHANGE_ME_random_64hex_for_access
JWT_REFRESH_SECRET=CHANGE_ME_random_64hex_for_refresh

# ── Seed (used once on first boot to create the 7 default users) ──────
SEED_DEFAULT_PASSWORD=CHANGE_ME_strong_admin_password

# ── Public URL config ───────────────────────────────────────────────────
# What the user types in the browser. Used by the web app for absolute
# links, and by the API as the only allowed CORS origin.
PUBLIC_BASE_URL=http://161.97.116.153:8080
CORS_ALLOWED_ORIGINS=http://161.97.116.153:8080
PUBLIC_DEFAULT_LOCALE=en

# ── Host port the Nginx container will publish ──────────────────────────
PUBLIC_HTTP_PORT=8080
