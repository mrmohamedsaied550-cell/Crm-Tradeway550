# syntax=docker/dockerfile:1.7
# Production image for @crm/web (Next.js 14, App Router).
# Builds with full deps then ships a self-contained `pnpm deploy` payload
# (no workspace symlinks) plus the .next build output.
ARG NODE_VERSION=20.18.0

FROM node:${NODE_VERSION}-bookworm-slim AS base
ENV PNPM_HOME=/usr/local/share/pnpm \
    PATH=/usr/local/share/pnpm:$PATH
RUN corepack enable && corepack prepare pnpm@9.0.0 --activate
RUN apt-get update && apt-get install -y --no-install-recommends \
        ca-certificates curl tini \
    && rm -rf /var/lib/apt/lists/*
WORKDIR /repo

# ---------- builder ----------
FROM base AS builder
COPY pnpm-workspace.yaml package.json pnpm-lock.yaml tsconfig.base.json ./
COPY apps/api/package.json apps/api/
# Workspace install runs the api postinstall (`prisma generate`) too,
# so the schema must already exist on disk.
COPY apps/api/prisma apps/api/prisma
COPY apps/web/package.json apps/web/
COPY packages/ packages/
RUN pnpm install --frozen-lockfile=false --prefer-offline
COPY apps/web/ apps/web/
ENV NEXT_TELEMETRY_DISABLED=1
RUN pnpm --filter @crm/web build
# Self-contained, prod-only deps for the web app.
RUN pnpm --filter @crm/web deploy --prod /deploy/web

# ---------- runtime ----------
FROM base AS runtime
ENV NODE_ENV=production \
    NEXT_TELEMETRY_DISABLED=1 \
    PORT=3001 \
    HOSTNAME=0.0.0.0
WORKDIR /app
# Self-contained node_modules + package.json from `pnpm deploy`.
COPY --from=builder /deploy/web/package.json ./package.json
COPY --from=builder /deploy/web/node_modules ./node_modules
# The Next.js build output and runtime config + i18n catalogues.
COPY --from=builder /repo/apps/web/.next ./.next
COPY --from=builder /repo/apps/web/next.config.mjs ./next.config.mjs
COPY --from=builder /repo/apps/web/i18n ./i18n
HEALTHCHECK --interval=15s --timeout=5s --start-period=30s --retries=10 \
  CMD curl -fsS http://127.0.0.1:${PORT}/login || exit 1
EXPOSE 3001
ENTRYPOINT ["/usr/bin/tini","--"]
CMD ["node","node_modules/next/dist/bin/next","start","-p","3001","-H","0.0.0.0"]
