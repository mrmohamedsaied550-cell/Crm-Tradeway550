// Trade Way / Captain Masr CRM — Prisma schema.
//
// C6 introduced the cross-tenant `Tenant` registry + the current_tenant_id()
// helper that every tenant-scoped RLS policy reuses.
// C7 introduces the RBAC catalogue: capabilities (global) plus tenant-scoped
// roles + role↔capability mappings.
// C8 introduces the tenant-scoped `User` model with bcrypt password hashing.
// C9 introduces `UserSession` (refresh-token storage) for the auth API.
// C10 introduces the CRM core: PipelineStage + Lead + Captain + LeadActivity.
// C11 adds response-SLA tracking + auto round-robin reassignment on breach.
// C12 introduces the org structure: Company → Country → Team, plus Team
//     membership on User (nullable, since super_admin / ops are tenant-wide).
// C18 extends Captain with name / phone / teamId / status (denormalised from
//     the lead at convert time; kept additive — no breaking changes).
// C21 introduces WhatsApp foundation: WhatsAppAccount (provider config per
//     tenant) + WhatsAppMessage (inbound + outbound traffic log).
// C22 introduces WhatsAppConversation: per (account × other-party-phone)
//     thread; messages attach to a conversation and the conversation
//     summary tracks the most recent message timestamp + body.
//
// Documentation: https://www.prisma.io/docs

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// A tenant — one isolated logical CRM workspace.
/// MVP runs as single-tenant; the column is added everywhere from day 1 so
/// multi-tenant rollout in Phase 2 is a configuration change, not a rewrite.
model Tenant {
  id        String   @id @default(uuid()) @db.Uuid
  code      String   @unique
  name      String
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  roles                       Role[]
  users                       User[]
  sessions                    UserSession[]
  settings                    TenantSettings?
  pipelines                   Pipeline[]
  pipelineStages              PipelineStage[]
  leads                       Lead[]
  captains                    Captain[]
  leadActivities              LeadActivity[]
  companies                   Company[]
  countries                   Country[]
  teams                       Team[]
  whatsAppAccounts            WhatsAppAccount[]
  whatsAppMessages            WhatsAppMessage[]
  whatsAppConversations       WhatsAppConversation[]
  whatsAppTemplates           WhatsAppTemplate[]
  bonusRules                  BonusRule[]
  bonusAccruals               BonusAccrual[]
  competitions                Competition[]
  leadFollowUps               LeadFollowUp[]
  auditEvents                 AuditEvent[]
  notifications               Notification[]
  metaLeadSources             MetaLeadSource[]
  captainDocuments            CaptainDocument[]
  captainTrips                CaptainTrip[]
  /// Phase 1A — distribution engine back-relations.
  distributionRules           DistributionRule[]
  agentCapacities             AgentCapacity[]
  leadRoutingLogs             LeadRoutingLog[]
  /// Phase A — per-tenant rejection-reason catalogue.
  lostReasons                 LostReason[]
  /// Phase C — C1: dynamic permissions back-relations.
  roleScopes                  RoleScope[]
  fieldPermissions            FieldPermission[]
  userScopeAssignments        UserScopeAssignment[]
  /// Phase C — C10B-1: WhatsApp ownership + contact identity.
  contacts                    Contact[]
  whatsAppConversationReviews WhatsAppConversationReview[]
  /// Phase D2 — D2.1: append-only duplicate-decision audit log.
  duplicateDecisionLogs       DuplicateDecisionLog[]
  /// Phase D3 — D3.3: per-(lead × stage) status history.
  leadStageStatuses           LeadStageStatus[]
  /// Phase D3 — D3.4: per-lead rotation history.
  leadRotationLogs            LeadRotationLog[]

  @@map("tenants")
}

/// A capability — a single permission the system understands. The catalogue
/// is global (one row per code, shared across tenants) so application code
/// can reference capability codes as a stable contract. Roles map to
/// capabilities per-tenant via RoleCapability.
model Capability {
  id          String   @id @default(uuid()) @db.Uuid
  code        String   @unique
  description String
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  roleCapabilities RoleCapability[]

  @@map("capabilities")
}

/// A role inside a single tenant.
///
/// `level` is a sortable hierarchy proxy (super_admin = 100, ops = 90,
/// account_manager = 80, team_leader = 60, qa_specialist = 50, agents = 30,
/// viewer = 20). Used by future scope guards for "rank-at-least" checks.
///
/// Phase C — C1: `isSystem` marks the 11 seeded role templates. System
/// roles are fully immutable at the service layer (C2): no rename, no
/// level change, no capability grant/revoke, no delete. Admins clone
/// them via `POST /rbac/roles/:id/duplicate` to customize.
/// `description` is admin-supplied helper text for the role builder UI.
model Role {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  code        String
  nameAr      String   @map("name_ar")
  nameEn      String   @map("name_en")
  level       Int
  isActive    Boolean  @default(true) @map("is_active")
  /// Phase C — C1: TRUE for the 11 seeded role templates. Service-
  /// layer guards block all mutations + deletion when set.
  isSystem    Boolean  @default(false) @map("is_system")
  /// Phase C — C1: optional admin-supplied description for the role
  /// builder UI. Free text; rendered as helper copy under the role
  /// name.
  description String?
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  capabilities     RoleCapability[]
  users            User[]
  bonusRules       BonusRule[]
  /// Phase C — C1: per-resource data scope ('own' | 'team' | 'company'
  /// | 'country' | 'global'). One row per (role, resource).
  scopes           RoleScope[]
  /// Phase C — C1: per-(resource, field) read/write toggles. Default
  /// for absent rows is read=TRUE / write=TRUE — restrictions are
  /// explicit denials.
  fieldPermissions FieldPermission[]

  @@unique([tenantId, code])
  @@index([tenantId, isActive])
  @@index([tenantId, isSystem])
  @@map("roles")
}

/// Mapping table: which capabilities a tenant's role grants. Tenant id is
/// denormalized for cheap RLS isolation (no JOIN to roles on every read).
/// The RLS WITH CHECK enforces that the column matches the active GUC, and
/// the FK to roles ensures the role exists.
model RoleCapability {
  tenantId     String   @map("tenant_id") @db.Uuid
  roleId       String   @map("role_id") @db.Uuid
  capabilityId String   @map("capability_id") @db.Uuid
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  capability Capability @relation(fields: [capabilityId], references: [id], onDelete: Cascade)

  @@id([roleId, capabilityId])
  @@index([tenantId])
  @@index([capabilityId])
  @@map("role_capabilities")
}

/// Phase C — C1: per-resource data scope for a role.
///
/// One row per (role × resource). The `scope` value drives the
/// service-layer filter (C3) that ANDs into every list/find query
/// for the resource:
///
///   'own'      WHERE assignedToId = :userId
///   'team'     WHERE assignedToId IN (members of :userTeamId)
///   'company'  WHERE companyId IN (:userScopeAssignments.companyIds)
///   'country'  WHERE countryId IN (:userScopeAssignments.countryIds)
///   'global'   no extra filter (legacy / admin behaviour).
///
/// The 11 seeded system roles all default to 'global' so the existing
/// 452 tests are unaffected. Custom roles created via the UI in C8
/// pick a per-resource scope.
///
/// Resources currently supported: lead, captain, followup,
/// whatsapp.conversation. Extending the list = add a row to the
/// `(resource)` CHECK constraint via a follow-up migration + the
/// service registry that consumes this table.
model RoleScope {
  tenantId  String   @map("tenant_id") @db.Uuid
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  roleId    String   @map("role_id") @db.Uuid
  role      Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  resource  String
  scope     String
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@id([roleId, resource])
  @@index([tenantId, resource])
  @@map("role_scopes")
}

/// Phase C — C1: per-(role × resource × field) read/write toggle.
///
/// Default for absent rows is read=TRUE / write=TRUE — restrictions
/// are explicit denials, not whitelists. C4 wires read-side
/// enforcement at the service exit; C5 wires write-side at the DTO
/// boundary. Field paths use dot-syntax for nested JSON, eg.
/// 'attribution.campaign.id'.
///
/// The seed installs 3 deny rows for the `sales_agent` role on the
/// `lead` resource:
///   - 'id'                    canRead = FALSE
///   - 'attribution.campaign'  canRead = FALSE
///   - 'source'                canRead = FALSE
/// Until C4 ships, these rows are present but unread, so the test
/// suite is unaffected.
model FieldPermission {
  tenantId  String   @map("tenant_id") @db.Uuid
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  roleId    String   @map("role_id") @db.Uuid
  role      Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  resource  String
  field     String
  canRead   Boolean  @default(true) @map("can_read")
  canWrite  Boolean  @default(true) @map("can_write")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@id([roleId, resource, field])
  @@index([tenantId, resource])
  @@map("field_permissions")
}

/// Phase C — C1: binds a user to one or more (company, country)
/// tuples for the `company` and `country` data scopes.
///
/// At least one of `companyId` / `countryId` must be set (CHECK
/// constraint in the migration). A user can be assigned to N rows —
/// e.g. an account manager covering EG-Uber and EG-inDrive gets two
/// rows. No backfill on existing users; they keep their current
/// 'global' behaviour because every system role's RoleScope row is
/// 'global' by default.
///
/// Resolution rule (C9):
///   - 'company' scope → (lead.companyId IN userCompanyIds) OR
///                       (lead.countryId IN userCountryIds where
///                        company is implicit through country.companyId).
///   - 'country' scope → (lead.countryId IN userCountryIds).
model UserScopeAssignment {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId    String   @map("user_id") @db.Uuid
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyId String?  @map("company_id") @db.Uuid
  company   Company? @relation(fields: [companyId], references: [id], onDelete: Cascade)
  countryId String?  @map("country_id") @db.Uuid
  country   Country? @relation(fields: [countryId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@unique([userId, companyId, countryId])
  @@index([tenantId, userId])
  @@index([tenantId, companyId])
  @@index([tenantId, countryId])
  @@map("user_scope_assignments")
}

/// A user inside a single tenant.
///
/// Email is unique per tenant (case-insensitive: stored already-lowercased).
/// Globally-unique email is intentionally NOT enforced — different tenants
/// may have users with the same address. Login flows resolve the tenant
/// before the email lookup (X-Tenant header in dev; JWT claim from C9).
///
/// `passwordHash` is bcrypt-hashed and must NEVER be returned by any public
/// service method. UsersService exposes a `SafeUser` projection that omits
/// the column; the only function that reads it is the internal
/// `verifyPasswordById` used by the login flow added in C9.
model User {
  id           String  @id @default(uuid()) @db.Uuid
  tenantId     String  @map("tenant_id") @db.Uuid
  tenant       Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  email        String
  passwordHash String  @map("password_hash")
  name         String
  phone        String?
  language     String  @default("en") // 'ar' | 'en'

  roleId String @map("role_id") @db.Uuid
  role   Role   @relation(fields: [roleId], references: [id])

  /// Team membership (C12). Optional because tenant-wide roles
  /// (super_admin, ops_manager, account_manager) don't belong to a single
  /// team. Service-layer validation ensures the team is in the same tenant.
  teamId String? @map("team_id") @db.Uuid
  team   Team?   @relation(fields: [teamId], references: [id], onDelete: SetNull)

  /// `invited` (set by admin invite flow, password unset until first login),
  /// `active`, `disabled`.
  status String @default("active")

  mfaEnabled       Boolean   @default(false) @map("mfa_enabled")
  mfaSecret        String?   @map("mfa_secret")
  lastLoginAt      DateTime? @map("last_login_at") @db.Timestamptz(6)
  failedLoginCount Int       @default(0) @map("failed_login_count")
  lockedUntil      DateTime? @map("locked_until") @db.Timestamptz(6)
  /// Phase 1A — feeds the round_robin distribution strategy. NULL =
  /// "never assigned via the engine", treated as oldest by the picker
  /// so brand-new agents enter the rotation first.
  lastAssignedAt   DateTime? @map("last_assigned_at") @db.Timestamptz(6)

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  sessions                    UserSession[]
  // Back-relations for CRM core (C10). A user may own / be assigned to leads
  // and may author activities. Kept on the User side so we can later list
  // "all leads I created" or "all activities I logged" without a JOIN
  // through the join table.
  createdLeads                Lead[]                 @relation("LeadCreator")
  assignedLeads               Lead[]                 @relation("LeadAssignee")
  /// Phase D2 — D2.1: back-relation for `Lead.reactivatedById`.
  /// Empty until D2.3 wires the reactivation path; kept here so
  /// the schema compiles and so future "leads I reactivated"
  /// reports don't need a round-trip through DuplicateDecisionLog.
  reactivatedLeads            Lead[]                 @relation("LeadReactivator")
  /// Phase D2 — D2.1: back-relation for the actor who took a
  /// duplicate decision (auto or manual).
  duplicateDecisions          DuplicateDecisionLog[] @relation("DuplicateDecisionActor")
  authoredActivities          LeadActivity[]
  /// C36 — follow-ups the user is responsible for. The owner of a
  /// follow-up is `assignedToId`; `createdById` is who scheduled it
  /// (may be the same).
  assignedFollowUps           LeadFollowUp[]         @relation("LeadFollowUpAssignee")
  createdFollowUps            LeadFollowUp[]         @relation("LeadFollowUpCreator")
  /// C40 — audit-event rows authored by this user.
  auditEvents                 AuditEvent[]
  /// P2-02 — in-app notifications addressed to this user.
  notifications               Notification[]
  /// P2-03 — bonus accruals earned by this user.
  bonusAccruals               BonusAccrual[]         @relation("BonusAccrualRecipient")
  /// P2-09 — captain-document review trail.
  reviewedDocuments           CaptainDocument[]      @relation("CaptainDocumentReviewer")
  uploadedDocuments           CaptainDocument[]      @relation("CaptainDocumentUploader")
  /// Phase 1A — distribution engine back-relations.
  agentCapacity               AgentCapacity?
  routedLeads                 LeadRoutingLog[]       @relation("LeadRoutingLogChosen")
  authoredDistributionRules   DistributionRule[]     @relation("DistributionRuleAuthor")
  targetedByDistributionRules DistributionRule[]     @relation("DistributionRuleTargetUser")
  /// Phase C — C1: per-user (company × country) scope bindings used
  /// by the 'company' / 'country' data scopes. Empty = no extra
  /// access path beyond `own` / `team`.
  scopeAssignments            UserScopeAssignment[]
  /// Phase C — C10B-1: WhatsApp conversations currently assigned to
  /// this user. Set by the inbound router or manual handover.
  whatsappConversations       WhatsAppConversation[] @relation("WhatsAppConversationAssignee")
  /// Phase D3 — D3.3: stage-status rows authored by this user. Empty
  /// until D3.3 wires the agent picker.
  authoredStageStatuses       LeadStageStatus[]      @relation("LeadStageStatusAuthor")
  /// Phase D3 — D3.4: rotation-log back-relations. Empty until the
  /// engine ships in D3.4.
  rotatedFromLogs             LeadRotationLog[]      @relation("LeadRotationLogFromUser")
  rotatedToLogs               LeadRotationLog[]      @relation("LeadRotationLogToUser")
  triggeredRotations          LeadRotationLog[]      @relation("LeadRotationLogActor")

  @@unique([tenantId, email])
  @@index([tenantId, status])
  @@index([tenantId, roleId])
  @@index([tenantId, teamId])
  @@map("users")
}

/// A refresh-token-backed session.
///
/// Refresh tokens are stored as SHA-256 of the raw token (the raw token
/// only lives in the client cookie and the JWT body). The hash is what
/// we look up + revoke. The unique partial index on `refresh_token_hash`
/// (where revoked_at IS NULL) lets the same physical bytes be re-issued
/// after revocation in the unlikely event of a hash collision.
///
/// On rotation we mark the old session `revoked_at = now` and link the
/// new session via `replaced_by_id`. Reuse-detection in C9 uses that
/// chain: if a client presents a refresh token whose row already has
/// `revoked_at`, every descendant session is revoked too.
model UserSession {
  id               String    @id @default(uuid()) @db.Uuid
  tenantId         String    @map("tenant_id") @db.Uuid
  tenant           Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId           String    @map("user_id") @db.Uuid
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  refreshTokenHash String    @map("refresh_token_hash")
  userAgent        String?   @map("user_agent")
  ip               String?
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  expiresAt        DateTime  @map("expires_at") @db.Timestamptz(6)
  revokedAt        DateTime? @map("revoked_at") @db.Timestamptz(6)
  replacedById     String?   @map("replaced_by_id") @db.Uuid

  @@index([tenantId, userId])
  @@index([refreshTokenHash])
  @@map("user_sessions")
}

/// PipelineStage — one node in a tenant's lead funnel.
/// Pipeline (P2-07) — admin-managed lead funnel, scoped at the tenant
/// level OR narrowed to a (Company × Country) pair.
///
/// Every tenant has exactly one "default" pipeline (`isDefault = true`,
/// `companyId IS NULL`, `countryId IS NULL`) which owns the canonical
/// 5-stage funnel produced by the seed. Admins can create additional
/// pipelines for specific (Company, Country) tuples to override the
/// stage list per market. The default pipeline is the fallback for
/// every code path that resolves a stage by code without context
/// (CSV import, Meta lead-gen, manual lead creation, conversion).
///
/// Routing of new leads to non-default pipelines (i.e. picking the
/// per-market pipeline at lead-create time based on `companyId` /
/// `countryId`) lands in a follow-up alongside Lead.companyId — the
/// schema here is the foundation.
model Pipeline {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  /// Optional Company narrowing. NULL = pipeline is not Company-scoped.
  companyId String?  @map("company_id") @db.Uuid
  company   Company? @relation(fields: [companyId], references: [id], onDelete: Restrict)
  /// Optional Country narrowing. NULL = pipeline is not Country-scoped.
  countryId String?  @map("country_id") @db.Uuid
  country   Country? @relation(fields: [countryId], references: [id], onDelete: Restrict)
  name      String
  /// Exactly one row per tenant must have `isDefault = true`. Enforced
  /// by a partial unique index in the migration (`WHERE is_default`).
  isDefault Boolean  @default(false) @map("is_default")
  isActive  Boolean  @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  stages PipelineStage[]
  /// Phase 1B — leads denormalised onto the pipeline they currently run on.
  leads  Lead[]

  // A given (tenant, company, country) pair can have at most one
  // pipeline row. The tenant-default sits at (tenantId, NULL, NULL)
  // and is also covered by this constraint (NULLs treated as distinct
  // by Postgres, but the partial-unique on isDefault forces single
  // default per tenant).
  @@unique([tenantId, companyId, countryId])
  @@index([tenantId, isActive])
  @@map("pipelines")
}

/// PipelineStage — one ordered stage inside a Pipeline. `order` is
/// unique within the parent pipeline so an admin UI can render the
/// list deterministically. `isTerminal` flags Converted / Lost so
/// reports can exclude them from "active" KPIs.
///
/// `tenantId` is duplicated from the parent pipeline so the FORCE'd
/// RLS policy can do a single GUC compare without joining.
model PipelineStage {
  id           String   @id @default(uuid()) @db.Uuid
  tenantId     String   @map("tenant_id") @db.Uuid
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  pipelineId   String   @map("pipeline_id") @db.Uuid
  pipeline     Pipeline @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  code         String
  name         String
  order        Int
  isTerminal   Boolean  @default(false) @map("is_terminal")
  /// Phase A — A1: classifies a terminal stage as 'won' or 'lost'.
  /// Drives `Lead.lifecycleState` on stage moves. NULL on non-terminal
  /// stages and on terminal stages that are neither (rare; admin can
  /// configure later via Pipeline Builder).
  terminalKind String?  @map("terminal_kind")

  /// Phase D3 — D3.1: per-stage SLA override.
  /// When NULL, the SLA budget falls back to `tenant_settings.slaMinutes`
  /// (the legacy tenant-wide default — preserved bit-for-bit so
  /// existing tenants see no behaviour change). When set, this value
  /// wins. The threshold engine (D3.2) reads
  /// `stage.slaMinutes ?? tenantSlaMinutes` on every recompute.
  /// `slaBusinessHoursOnly` is the seam for future country-holiday-
  /// aware budgets — D3.1 ships the column only; the engine treats it
  /// as `false` regardless until the calendar service lands.
  /// `autoActions` is the seam for future entry/exit hooks (notify,
  /// reassign team, set tag) the Pipeline Builder will configure;
  /// D3.1 ships the column only — no consumer reads it yet.
  slaMinutes           Int?     @map("sla_minutes")
  slaBusinessHoursOnly Boolean  @default(false) @map("sla_business_hours_only")
  autoActions          Json?    @map("auto_actions")

  /// Phase D3 — D3.3: stage-specific status catalogue.
  /// `allowedStatuses` is a JSONB array of `{ code, label, labelAr }`
  /// objects defining the operational sub-states an agent can record
  /// inside this stage (e.g. for "First Contact": Interested /
  /// No Answer / Wrong Number / Call Later). NULL or empty = no
  /// statuses configured for the stage; the picker renders a hint
  /// instead of a disabled dropdown. Validated at the service layer
  /// — see `LeadStageStatusService`.
  /// `requireStatusOnExit` is enforced ONLY under D3_ENGINE_V1=true:
  /// when leaving a stage with this flag set, the agent must have
  /// recorded at least one status row for the (lead, stage) since
  /// the stage was entered. Flag-off = inert (existing moveStage
  /// behaviour byte-identical).
  allowedStatuses      Json?    @map("allowed_statuses")
  requireStatusOnExit  Boolean  @default(false) @map("require_status_on_exit")

  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  leads         Lead[]
  /// Phase D3 — D3.3: every status row recorded against this stage.
  /// Empty until D3.3 wires the agent picker.
  stageStatuses LeadStageStatus[]

  @@unique([pipelineId, code])
  @@unique([pipelineId, order])
  @@index([tenantId])
  @@index([pipelineId])
  @@map("pipeline_stages")
}

/// Lead — a prospective captain in the funnel.
/// Phone is normalised to E.164 before insert (see crm/phone.util.ts) and
/// is unique per tenant so the same human cannot exist twice. The optional
/// 1-1 Captain relation lives on the Captain side (`captains.lead_id`
/// UNIQUE) — a Lead has at-most-one Captain via the back-relation.
model Lead {
  id       String  @id @default(uuid()) @db.Uuid
  tenantId String  @map("tenant_id") @db.Uuid
  tenant   Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name     String
  phone    String
  email    String?
  source   String  @default("manual")

  /// Phase 1B — B1: explicit (company, country) scope on the lead.
  /// Both nullable: a lead with NULL/NULL falls back to the tenant's
  /// default pipeline at read time (preserves pre-1B behaviour).
  /// Once the Pipeline Builder is the canonical surface, new leads
  /// get these populated based on the source / form they came from.
  companyId String?  @map("company_id") @db.Uuid
  company   Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)
  countryId String?  @map("country_id") @db.Uuid
  country   Country? @relation(fields: [countryId], references: [id], onDelete: SetNull)

  stageId String        @map("stage_id") @db.Uuid
  stage   PipelineStage @relation(fields: [stageId], references: [id])

  /// Phase 1B — B1: denormalised pipeline pointer. Always equal to
  /// `stage.pipelineId`; kept on the row so Kanban / reporting can
  /// filter by pipeline without joining stages, and so a stage move
  /// guard can catch cross-pipeline transitions cheaply.
  /// Nullable today; will be promoted to NOT NULL after B3 ships
  /// and a backfill window closes.
  pipelineId String?   @map("pipeline_id") @db.Uuid
  pipeline   Pipeline? @relation(fields: [pipelineId], references: [id], onDelete: Restrict)

  assignedToId String? @map("assigned_to_id") @db.Uuid
  assignedTo   User?   @relation("LeadAssignee", fields: [assignedToId], references: [id])

  createdById String? @map("created_by_id") @db.Uuid
  createdBy   User?   @relation("LeadCreator", fields: [createdById], references: [id])

  /// Response-SLA tracking (C11).
  /// `slaDueAt` is when the assigned agent must produce a `note` or `call`
  /// activity by; null when the lead is in a terminal stage (Converted /
  /// Lost) and the SLA is paused.
  /// `slaStatus`: 'active' | 'breached' | 'paused'.
  /// `lastResponseAt` is the timestamp of the most recent agent-driven
  /// activity (note/call/stage_change/assignment); used both for the
  /// reset-on-activity rule and for reporting.
  slaDueAt       DateTime? @map("sla_due_at") @db.Timestamptz(6)
  slaStatus      String    @default("active") @map("sla_status")
  lastResponseAt DateTime? @map("last_response_at") @db.Timestamptz(6)

  /// Phase D3 — D3.1: SLA threshold tracking.
  /// `slaThreshold` records WHICH ladder bucket the lead currently sits
  /// in:
  ///   'ok'    — ratio (elapsed/budget) < 0.75
  ///   't75'   — 0.75 ≤ ratio < 1.00 (soft reminder)
  ///   't100'  — 1.00 ≤ ratio < 1.50 (warning, tag at-risk)
  ///   't150'  — 1.50 ≤ ratio < 2.00 (escalation; first occurrence
  ///             auto-rotates per tenant policy, second occurrence
  ///             within 24h raises a TL Review Queue item instead)
  ///   't200'  — ratio ≥ 2.00 (high escalation; raises TL review)
  /// Defaults to 'ok' for every existing row at migration time and
  /// for every newly-created lead. The engine (D3.2) recomputes the
  /// bucket on every scheduler tick + on every stage move / response.
  /// `slaThresholdAt` records WHEN the current bucket was entered —
  /// drives the audit trail and the 24-hour repeat-window check for
  /// t150 escalations.
  /// `lastRotatedAt` mirrors the most recent LeadRotationLog row's
  /// timestamp for the lead. Denormalised so list queries can filter
  /// "rotated in the last 24h" without joining; populated when the
  /// rotation engine (D3.4) writes a rotation log. NULL until then.
  /// All three columns are inert in D3.1 — no service reads or
  /// writes them yet. Wired in D3.2 (threshold engine) and D3.4
  /// (rotation engine).
  slaThreshold    String    @default("ok") @map("sla_threshold")
  slaThresholdAt  DateTime? @map("sla_threshold_at") @db.Timestamptz(6)
  lastRotatedAt   DateTime? @map("last_rotated_at") @db.Timestamptz(6)

  /// Phase D3 — D3.3: denormalised pointer to the latest
  /// LeadStageStatus row for the lead's CURRENT stage. NULL when
  /// the agent hasn't recorded a status yet on this stage attempt.
  /// Cleared by `LeadsService.moveStage` when the stage changes
  /// (under D3_ENGINE_V1=true) so a stale status from the previous
  /// stage doesn't bleed into the new one. ON DELETE SET NULL so a
  /// hard-deleted history row never cascades into the lead.
  currentStageStatusId String?           @map("current_stage_status_id") @db.Uuid
  currentStageStatus   LeadStageStatus?  @relation("LeadCurrentStageStatus", fields: [currentStageStatusId], references: [id], onDelete: SetNull)
  /// Back-relation for every LeadStageStatus row historically
  /// written for this lead (across stages and attempts).
  stageStatuses        LeadStageStatus[] @relation("LeadStageStatusHistory")
  /// Phase D3 — D3.4: append-only rotation-history rows for the lead.
  /// Sales agents see a redacted view (no from/to user names);
  /// TL+ see the full from/to chain. Visibility gate lives in
  /// `RotationService`. Empty until D3.4's first rotation lands.
  rotationLogs         LeadRotationLog[]

  /// Discipline tracking (C37).
  /// `lastActivityAt` is the timestamp of the most recent activity row
  /// of any type — denormalised from MAX(lead_activities.created_at)
  /// so the agent inbox can sort / filter without joining.
  /// `nextActionDueAt` is the dueAt of the soonest pending follow-up
  /// (LeadFollowUp where completedAt IS NULL). The follow-ups service
  /// keeps this in sync on insert / complete / delete. Used for the
  /// /leads/overdue and /leads/due-today endpoints + the agent
  /// workspace's red-amber counters.
  lastActivityAt  DateTime? @map("last_activity_at") @db.Timestamptz(6)
  nextActionDueAt DateTime? @map("next_action_due_at") @db.Timestamptz(6)

  /// Phase A — A1: lifecycle classifier derived from the lead's
  /// current stage's `terminalKind`. Single source of truth for
  /// "is this lead in the funnel, won, or lost?" — used by reports,
  /// dashboards, and capacity calculations. NEVER set directly via
  /// the API; only LeadsService.moveStage / convertToCaptain may
  /// write it.
  ///   'open'     — non-terminal stage; agent is working it.
  ///   'won'      — entered a stage with terminalKind='won' (e.g. converted).
  ///   'lost'     — entered a stage with terminalKind='lost'; requires lostReasonId.
  ///   'archived' — manually retired (rare; admin-only undo path).
  lifecycleState String @default("open") @map("lifecycle_state")

  /// Phase A — A1: required when lifecycleState='lost'. References
  /// the per-tenant `lost_reasons` catalogue. Cleared automatically
  /// when the lead is moved back to a non-lost stage.
  lostReasonId String?     @map("lost_reason_id") @db.Uuid
  lostReason   LostReason? @relation(fields: [lostReasonId], references: [id], onDelete: Restrict)
  /// Optional free-text elaboration on the lost reason.
  lostNote     String?     @map("lost_note")

  /// Phase A — A1: rich attribution payload (source, campaign, ad
  /// set, ad, UTM). Populated on every create path (Meta webhook,
  /// CSV import, manual). Distribution rules + reporting will read
  /// from this in Phase D. Backfilled to `{ source: <flat source> }`
  /// for legacy rows; `Lead.source` is preserved for backward compat.
  attribution Json? @map("attribution")

  /// Phase C — C10B-1: stable identity for the person behind a phone.
  /// One Contact per (tenantId, phone); a single Contact may be tied
  /// to multiple Leads across the funnel's lifetime (re-entry, churn,
  /// captain → re-lead). Nullable for now — backfill happens in B2.
  contactId String?  @map("contact_id") @db.Uuid
  contact   Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)

  /// Phase C — C10B-1: latest WhatsApp conversation for this lead, if
  /// any. Set by the inbound flow (B3) when a conversation is auto-
  /// linked or when an agent links manually. Optional and SetNull on
  /// conversation delete so a closed conversation doesn't cascade-
  /// delete the lead. Read-only "open chat from lead" pointer — the
  /// authoritative lead↔conversation relation is the conversation's
  /// own `leadId` column (multiple conversations may map to one lead
  /// over time).
  primaryConversationId String?               @map("primary_conversation_id") @db.Uuid
  primaryConversation   WhatsAppConversation? @relation("LeadPrimaryConversation", fields: [primaryConversationId], references: [id], onDelete: SetNull)

  /// Phase D2 — D2.1: multi-attempt foundation.
  /// `attemptIndex` numbers attempts within a (tenant, contact) chain;
  /// every existing row is attempt 1 (default). Backfills as 1 for any
  /// future legacy rows that lack a contactId. Future create paths
  /// (D2.3) bump this when reactivating; D2.1 itself does not.
  /// `previousLeadId` chains the row to the prior attempt for the same
  /// contact, so the UI can render an "Attempt N of M" history without
  /// a window function. Self-reference; SetNull on delete so removing a
  /// historical attempt doesn't cascade-delete the chain.
  /// `reactivatedAt` / `reactivatedById` / `reactivationRule` capture
  /// the moment a fresh attempt was created from a closed predecessor.
  /// `reactivationRule` is one of the rule codes the future
  /// DuplicateRulesService emits (`reactivate_lost_aged_out`,
  /// `reactivate_no_answer_aged_out`, `manual_override`, …).
  /// All four columns are NULL on D2.1 — no runtime path writes them
  /// yet. Wired in D2.2 / D2.3.
  attemptIndex     Int       @default(1) @map("attempt_index")
  previousLeadId   String?   @map("previous_lead_id") @db.Uuid
  previousLead     Lead?     @relation("LeadAttemptChain", fields: [previousLeadId], references: [id], onDelete: SetNull)
  nextAttempts     Lead[]    @relation("LeadAttemptChain")
  reactivatedAt    DateTime? @map("reactivated_at") @db.Timestamptz(6)
  reactivatedById  String?   @map("reactivated_by_id") @db.Uuid
  reactivatedBy    User?     @relation("LeadReactivator", fields: [reactivatedById], references: [id])
  reactivationRule String?   @map("reactivation_rule")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  captain               Captain?
  activities            LeadActivity[]
  whatsappConversations WhatsAppConversation[] @relation("ConversationLead")
  followUps             LeadFollowUp[]
  /// Phase 1A — append-only routing decisions for this lead.
  routingLogs           LeadRoutingLog[]
  /// Phase D2 — D2.1: every duplicate-decision audit row that
  /// resolved to creating / linking THIS lead points back here.
  /// Read-only side; the writer is DuplicateDecisionLog itself.
  duplicateDecisions    DuplicateDecisionLog[] @relation("DuplicateDecisionResultLead")

  // Phase D2 — D2.3: the lifelong @@unique([tenantId, phone]) was
  // dropped in favour of a PARTIAL UNIQUE INDEX scoped to OPEN
  // leads only (`leads_open_phone_uniq` — see migration 0033).
  // Prisma 5 doesn't model partial-unique indexes in the schema
  // language; the index is created by raw SQL in the migration and
  // exists in the database, but is not declared here. The runtime
  // gate is DuplicateDecisionService (D2.2); the partial index is
  // the concurrent-race safety net. Multiple historical / lost /
  // won / archived leads with the same phone are expected and
  // permitted.
  @@index([tenantId, stageId])
  @@index([tenantId, assignedToId])
  @@index([tenantId, createdAt])
  // Hot path for the SLA breach scanner: `WHERE tenant=? AND slaStatus='active' AND slaDueAt < now`.
  @@index([tenantId, slaStatus, slaDueAt])
  // C37 — overdue / due-today scans by assignee + next action.
  @@index([tenantId, assignedToId, nextActionDueAt])
  // Phase 1B — Kanban: "all leads in pipeline X grouped by stage".
  @@index([tenantId, pipelineId, stageId])
  // Phase 1B — reporting + admin filters by (company, country).
  @@index([tenantId, companyId, countryId])
  // Phase A — workspace + reports filter by lifecycle state.
  @@index([tenantId, lifecycleState])
  // Phase C — C10B-1: lead lookups via contact identity.
  @@index([tenantId, contactId])
  // Phase D2 — D2.1: cheap "list attempts for this contact ordered
  // by attempt number" without a sort — supports the future Attempts
  // History card on the lead detail page.
  @@index([tenantId, contactId, attemptIndex])
  // Phase D3 — D3.1: hot path for the future threshold scheduler.
  // The recompute query is `WHERE tenant=? AND slaThreshold IN
  // ('ok','t75','t100','t150') AND slaDueAt IS NOT NULL`. The
  // composite index lets the scanner skip leads that are already
  // at 't200' (terminal threshold; nothing more for the engine to
  // do until the lead transitions out of 'open') and lets the UI
  // chip-filter "leads at t150 or worse" return without a sort.
  // Inert in D3.1 — no scanner reads it yet.
  @@index([tenantId, slaThreshold, slaDueAt])
  @@map("leads")
}

/// Phase D3 — D3.3: per-(lead × stage) status history.
///
/// Each row records ONE status the agent picked for a lead inside a
/// particular pipeline stage during a particular attempt — e.g. for
/// the "First Contact" stage: `status = 'no_answer'` after a missed
/// call. The latest row for a lead is denormalised onto
/// `Lead.currentStageStatusId` for cheap reads; the full history
/// stays here so reports / TL coaching dashboards can ask "how many
/// times did this lead hit no_answer before being lost?".
///
/// Status STRING is validated at the service layer against
/// `PipelineStage.allowedStatuses`. Storing it as TEXT (not an enum)
/// lets each tenant configure its own catalogue per stage without
/// schema migrations.
///
/// `attemptIndex` mirrors `Lead.attemptIndex` at write time so the
/// status row is forensically tied to the attempt it belonged to —
/// critical when a lead is reactivated (D2) and a fresh attempt's
/// status history must not leak into the predecessor's report.
///
/// FORCE RLS on `tenant_id`. ON DELETE CASCADE for tenant + lead;
/// ON DELETE SET NULL for the user (so disabling an agent doesn't
/// destroy their status-history audit trail).
model LeadStageStatus {
  id           String  @id @default(uuid()) @db.Uuid
  tenantId     String  @map("tenant_id") @db.Uuid
  tenant       Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  leadId       String  @map("lead_id") @db.Uuid
  lead         Lead    @relation("LeadStageStatusHistory", fields: [leadId], references: [id], onDelete: Cascade)
  stageId      String  @map("stage_id") @db.Uuid
  stage        PipelineStage @relation(fields: [stageId], references: [id], onDelete: Restrict)
  /// Stable code from `PipelineStage.allowedStatuses[].code`. Free
  /// string at the column level; validated at the service.
  status       String
  /// Snapshot of `Lead.attemptIndex` when this status was recorded.
  /// Lets reports filter "statuses for this attempt only".
  attemptIndex Int     @map("attempt_index")
  /// Author. NULL for system-driven future paths (none today).
  setByUserId  String? @map("set_by_user_id") @db.Uuid
  setBy        User?   @relation("LeadStageStatusAuthor", fields: [setByUserId], references: [id], onDelete: SetNull)
  /// Optional free-text note the agent supplied alongside the status.
  notes        String?

  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  /// Inverse relation pointing back from Lead.currentStageStatusId.
  currentForLeads Lead[] @relation("LeadCurrentStageStatus")

  @@index([tenantId, leadId, createdAt(sort: Desc)])
  @@index([tenantId, stageId, status])
  @@map("lead_stage_statuses")
}

/// Phase D3 — D3.4: append-only lead-rotation history.
///
/// Each row records ONE rotation — the moment a lead's owner changed,
/// the trigger (SLA breach, manual TL action, capacity-balance,
/// agent-unavailable), the handover mode (full / summary / clean),
/// and forensic context (reason code, free-text notes, optional
/// payload snapshot). Distinct from `LeadActivity { type: 'rotation' }`
/// — the activity row is the human-facing timeline entry, this
/// table is the structured query surface for "rotated to me in the
/// last 24h" agent-workspace banners and TL coaching dashboards.
///
/// Visibility:
///   The full `(fromUser, toUser, reasonCode, notes, payload)` set is
///   server-authoritative. The read endpoint redacts those fields
///   for callers that lack `lead.write` (D2.6 pattern; future
///   `lead.previous_owner.read` capability will replace it). The
///   table itself never deletes rows — the redaction happens at the
///   service-response layer.
///
/// `attemptIndex` snapshots `Lead.attemptIndex` so a rotation that
/// happened on attempt #2 doesn't get silently re-attributed to a
/// later attempt's report.
///
/// FORCE RLS on tenant_id (matches every other tenant-scoped table
/// in the schema).
model LeadRotationLog {
  id            String  @id @default(uuid()) @db.Uuid
  tenantId      String  @map("tenant_id") @db.Uuid
  tenant        Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  leadId        String  @map("lead_id") @db.Uuid
  lead          Lead    @relation(fields: [leadId], references: [id], onDelete: Cascade)
  /// Owner of the lead BEFORE the rotation. NULL when the lead was
  /// unassigned at rotation time (rare but possible — e.g. SLA
  /// breach on a lead the route engine had previously failed to
  /// place). SetNull on user delete so disabling an agent never
  /// destroys the audit trail.
  fromUserId    String? @map("from_user_id") @db.Uuid
  fromUser      User?   @relation("LeadRotationLogFromUser", fields: [fromUserId], references: [id], onDelete: SetNull)
  /// Owner AFTER the rotation. NULL when the route engine had no
  /// eligible agent and the lead was left unassigned (the activity
  /// row + log still record the attempt). SetNull on user delete.
  toUserId      String? @map("to_user_id") @db.Uuid
  toUser        User?   @relation("LeadRotationLogToUser", fields: [toUserId], references: [id], onDelete: SetNull)
  /// Free-text trigger code. Today: `sla_breach` | `manual_tl` |
  /// `manual_ops` | `agent_unavailable` | `capacity_balance`. Stored
  /// as TEXT (not enum) so future triggers don't need a migration.
  trigger       String
  /// Handover mode chosen at rotation time. `full` | `summary` |
  /// `clean`. Drives the new owner's view + the activity payload
  /// shape (see RotationService).
  handoverMode  String  @map("handover_mode")
  /// Optional stable code categorising the rotation (e.g.
  /// `sla_t150_breach`, `tl_capacity_balance`). Distinct from
  /// `trigger` — `trigger` is "what fired this", `reasonCode` is
  /// "what tag should the dashboard group it under".
  reasonCode    String? @map("reason_code")
  /// Free-text TL/Ops note. For Summary Transfer this is shown to
  /// the new owner; for Full / Clean it's TL+-only.
  notes         String?
  /// Forensic snapshot — anything the engine wants to preserve
  /// (matched rule id, eligibility filter results, etc.). Optional.
  payload       Json?
  /// Snapshot of `Lead.attemptIndex` at rotation time.
  attemptIndex  Int     @map("attempt_index")
  /// Actor — the user who triggered the rotation. NULL when the
  /// scheduler (system) initiated it.
  actorUserId   String? @map("actor_user_id") @db.Uuid
  actor         User?   @relation("LeadRotationLogActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  // Per-lead history (newest first) — drives the lead-detail card.
  @@index([tenantId, leadId, createdAt(sort: Desc)])
  // "rotated to me in the last 24h" — drives the agent-workspace
  // banner D3.7 ships.
  @@index([tenantId, toUserId, createdAt(sort: Desc)])
  // Per-trigger reporting (Ops dashboards, breach analytics).
  @@index([tenantId, trigger, createdAt(sort: Desc)])
  @@map("lead_rotation_logs")
}

/// Captain — a Lead converted to an active driver.
/// One-to-one with Lead via the unique `leadId`. Onboarding flags track
/// which documents have landed; an MVP scope (the full document
/// review/approval lifecycle from the PRD lands in a later chunk).
///
/// C18 denormalises `name` + `phone` from the lead at conversion time so
/// downstream captain-only screens don't need to JOIN through the lead;
/// adds an optional `teamId` (the activation/driving team that owns the
/// captain post-handover); adds a top-level lifecycle `status` distinct
/// from `onboardingStatus` (active / inactive / archived) so the captain
/// can be deactivated without touching the onboarding state.
model Captain {
  id       String @id @default(uuid()) @db.Uuid
  tenantId String @map("tenant_id") @db.Uuid
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  leadId   String @unique @map("lead_id") @db.Uuid
  lead     Lead   @relation(fields: [leadId], references: [id], onDelete: Cascade)

  /// Denormalised from the lead at conversion time.
  name  String
  phone String

  /// Activation / driving team that owns this captain (nullable —
  /// a freshly-converted captain may not yet be assigned to a team).
  teamId String? @map("team_id") @db.Uuid
  team   Team?   @relation(fields: [teamId], references: [id], onDelete: SetNull)

  /// Captain lifecycle status: 'active' | 'inactive' | 'archived'.
  status String @default("active")

  /// `pending`, `in_progress`, `active`, `rejected`.
  onboardingStatus       String    @default("pending") @map("onboarding_status")
  hasIdCard              Boolean   @default(false) @map("has_id_card")
  hasLicense             Boolean   @default(false) @map("has_license")
  hasVehicleRegistration Boolean   @default(false) @map("has_vehicle_registration")
  activatedAt            DateTime? @map("activated_at") @db.Timestamptz(6)

  /// P2-09 — trip telemetry. `firstTripAt` is the timestamp of the
  /// captain's first delivered trip; bonus rules with `bonusType =
  /// 'first_trip'` fire when this transitions from null. `tripCount`
  /// is monotonically non-decreasing — admin trip ingest writes
  /// incremental updates and is idempotent against the
  /// captain_trips ledger.
  firstTripAt DateTime? @map("first_trip_at") @db.Timestamptz(6)
  tripCount   Int       @default(0) @map("trip_count")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  bonusAccruals BonusAccrual[]
  documents     CaptainDocument[]
  trips         CaptainTrip[]

  @@index([tenantId, onboardingStatus])
  @@index([tenantId, status])
  @@index([tenantId, teamId])
  @@index([tenantId, firstTripAt])
  @@map("captains")
}

/// CaptainDocument (P2-09) — driver-onboarding paperwork.
///
/// MVP stores metadata only: the file upload itself goes through
/// the operator's existing storage pipeline (S3 / GCS / similar)
/// and is referenced by `storageRef`. The CRM records `kind`,
/// `status`, optional `expiresAt`, and the reviewer trail.
///
/// Statuses:
///   - `pending`   — uploaded; awaiting reviewer decision
///   - `approved`  — reviewer accepted; counts towards onboarding
///   - `rejected`  — reviewer rejected; reviewNotes carries reason
///   - `expired`   — expiresAt < now; flipped lazily on read or by
///                   a scheduled sweep (Phase 3)
///
/// `kind` is a free-form string with the canonical values
/// `id_card` / `license` / `vehicle_registration` / `other`. We keep
/// it open so a tenant in a market with extra paperwork (e.g. KSA
/// `iqama`) can extend without a schema change.
model CaptainDocument {
  id        String  @id @default(uuid()) @db.Uuid
  tenantId  String  @map("tenant_id") @db.Uuid
  tenant    Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  captainId String  @map("captain_id") @db.Uuid
  captain   Captain @relation(fields: [captainId], references: [id], onDelete: Cascade)

  kind       String
  storageRef String @map("storage_ref")
  fileName   String @map("file_name")
  mimeType   String @map("mime_type")
  sizeBytes  Int    @map("size_bytes")

  status    String    @default("pending")
  expiresAt DateTime? @map("expires_at") @db.Timestamptz(6)

  reviewerUserId String?   @map("reviewer_user_id") @db.Uuid
  reviewer       User?     @relation("CaptainDocumentReviewer", fields: [reviewerUserId], references: [id], onDelete: SetNull)
  reviewedAt     DateTime? @map("reviewed_at") @db.Timestamptz(6)
  reviewNotes    String?   @map("review_notes")

  uploadedById String? @map("uploaded_by_id") @db.Uuid
  uploadedBy   User?   @relation("CaptainDocumentUploader", fields: [uploadedById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([tenantId, captainId, status])
  @@index([tenantId, status, expiresAt])
  @@map("captain_documents")
}

/// CaptainTrip (P2-09) — append-only ledger of a captain's trips.
///
/// One row per delivered trip. The `tripId` is the operator's
/// external id (Uber / inDrive / ...) and is unique per captain so
/// the ingest endpoint is idempotent on retries.
///
/// We don't store the full trip payload here — just enough to drive
/// `Captain.tripCount` and `Captain.firstTripAt` updates and to feed
/// the `first_trips` competition metric. Trip data analytics belong
/// to a future warehouse pipeline.
model CaptainTrip {
  id         String   @id @default(uuid()) @db.Uuid
  tenantId   String   @map("tenant_id") @db.Uuid
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  captainId  String   @map("captain_id") @db.Uuid
  captain    Captain  @relation(fields: [captainId], references: [id], onDelete: Cascade)
  /// External id from the operator's system (Uber trip uuid, etc).
  tripId     String   @map("trip_id")
  occurredAt DateTime @map("occurred_at") @db.Timestamptz(6)
  payload    Json?

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@unique([captainId, tripId])
  @@index([tenantId, captainId, occurredAt])
  @@map("captain_trips")
}

/// LeadActivity — append-only log of touchpoints + system events on a lead.
/// `type` discriminates between agent-authored entries (`note`, `call`)
/// and system-generated ones (`stage_change`, `assignment`, `system`).
/// `payload` carries structured data for system events (e.g. from/to
/// stage codes) so the UI can render diffs without regex on the body.
model LeadActivity {
  id           String   @id @default(uuid()) @db.Uuid
  tenantId     String   @map("tenant_id") @db.Uuid
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  leadId       String   @map("lead_id") @db.Uuid
  lead         Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  type         String
  body         String?
  payload      Json?
  /// Phase C — C10B-1: provenance for the activity — which surface
  /// produced it. Lets the timeline + audit distinguish:
  ///   'lead'      — agent action inside the lead detail page (default).
  ///   'whatsapp'  — chat send/receive that mirrored to the activity feed.
  ///   'system'    — automation / SLA / distribution / bonus engine.
  ///   'import'    — CSV / batch import.
  /// Default 'lead' preserves existing behaviour for the 555 tests; the
  /// inbound flow (B3) and chat-send paths (B4) write 'whatsapp'.
  actionSource String   @default("lead") @map("action_source")
  createdById  String?  @map("created_by_id") @db.Uuid
  createdBy    User?    @relation(fields: [createdById], references: [id])
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([tenantId, leadId, createdAt])
  @@index([tenantId, type])
  @@map("lead_activities")
}

/// Company — a partner the tenant operates for (Uber, inDrive, Careem, …).
///
/// `code` is a short slug (e.g. `uber`, `indrive`) intended for URLs and
/// integration mappings (Meta form_id → Company × Country pipeline). It's
/// unique per tenant so two tenants can both have an `uber` row without
/// colliding. Soft-delete via `isActive`; the FK from Country uses
/// `onDelete: Restrict` so an in-use company cannot be hard-removed.
model Company {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  code      String
  name      String
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  countries             Country[]
  bonusRules            BonusRule[]
  competitions          Competition[]
  pipelines             Pipeline[]
  /// Phase 1A — distribution rules scoped to this company.
  distributionRules     DistributionRule[]
  /// Phase 1B — leads explicitly scoped to this company.
  leads                 Lead[]
  /// Phase C — C1: users granted access to this company via
  /// `company` / `country` data scopes.
  userScopeAssignments  UserScopeAssignment[]
  /// Phase C — C10B-1: WhatsApp conversations whose ownership chain
  /// resolves to this company.
  whatsappConversations WhatsAppConversation[]

  @@unique([tenantId, code])
  @@index([tenantId, isActive])
  @@map("companies")
}

/// Country — a (Company × Country) operating unit.
///
/// Each Country row is scoped to a specific Company so the same ISO code
/// (e.g. EG) can appear under multiple companies. Service-layer validation
/// enforces that `companyId` resolves to a row in the same tenant — RLS on
/// Company already returns null cross-tenant, so the lookup itself is the
/// guard.
model Country {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  companyId String   @map("company_id") @db.Uuid
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Restrict)
  code      String
  name      String
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  teams                 Team[]
  bonusRules            BonusRule[]
  competitions          Competition[]
  pipelines             Pipeline[]
  /// Phase 1A — distribution rules scoped to this country.
  distributionRules     DistributionRule[]
  /// Phase 1B — leads explicitly scoped to this country.
  leads                 Lead[]
  /// Phase C — C1: users granted access to this country via the
  /// `country` data scope.
  userScopeAssignments  UserScopeAssignment[]
  /// Phase C — C10B-1: WhatsApp conversations whose ownership chain
  /// resolves to this country.
  whatsappConversations WhatsAppConversation[]

  // Same code may exist under different companies in one tenant, so the
  // uniqueness constraint includes companyId.
  @@unique([tenantId, companyId, code])
  @@index([tenantId, companyId])
  @@map("countries")
}

/// Team — a working group inside a (Company × Country).
///
/// Teams are the unit users belong to. `name` is unique per country so a
/// "Sales" team can exist under (Uber, EG) and (inDrive, EG) without
/// colliding. Disabling a team only flips `isActive` — the FK from User
/// uses `SetNull` so users in a deleted team aren't orphan-blocked.
model Team {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  countryId String   @map("country_id") @db.Uuid
  country   Country  @relation(fields: [countryId], references: [id], onDelete: Restrict)
  name      String
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  users                 User[]
  captains              Captain[]
  bonusRules            BonusRule[]
  competitions          Competition[]
  /// Phase 1A — distribution rules that target this team's pool.
  distributionRules     DistributionRule[]
  /// Phase C — C10B-1: WhatsApp conversations currently owned by an
  /// agent in this team (denormalised for scope resolution).
  whatsappConversations WhatsAppConversation[]

  @@unique([tenantId, countryId, name])
  @@index([tenantId, countryId])
  @@map("teams")
}

/// Phase C — C10B-1: Contact — stable identity for the human behind a
/// phone number, decoupled from the lead lifecycle.
///
/// One row per (tenantId, phone). Multiple Lead rows may point at the
/// same Contact across the customer's lifetime: a churned lead who
/// re-applies, a captain who later re-enters as a lead in a different
/// country, etc. The Lead remains the source of truth for
/// pipeline-state (stage / lifecycleState / next actions); Contact
/// holds the stable phone identity + the WhatsApp profile snapshot.
///
/// `displayName` is the latest WhatsApp profile name we've seen
/// (mutable — overwritten on every inbound webhook). `originalDisplayName`
/// and `originalPhone` capture the FIRST values we observed and are
/// never overwritten — they preserve the raw provider-supplied identity
/// for audit / dedupe even after agents clean up the lead.
/// `rawProfile` stores the verbatim provider profile payload (Meta's
/// `contacts[0].profile.*`) in case future fields land before a schema
/// migration ships.
///
/// Denormalised flags `isCaptain` / `hasOpenLead` let the inbound
/// router decide between "auto-create lead", "link to existing lead",
/// and "queue for review" in O(1) without a join. They are kept in
/// sync by lead/captain create/update triggers (wired in B3).
model Contact {
  id       String @id @default(uuid()) @db.Uuid
  tenantId String @map("tenant_id") @db.Uuid
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  /// E.164 normalised phone (e.g. `+201001234567`). Unique per tenant.
  phone               String
  /// Latest known WhatsApp profile name. Mutable — overwritten on
  /// every inbound webhook that carries a profile payload.
  displayName         String? @map("display_name")
  /// Optional language hint sourced from the WhatsApp profile (e.g.
  /// 'ar', 'en', 'ar-EG'). Used by the inbound flow to choose a
  /// default lead language without prompting.
  language            String?
  /// Raw provider profile payload — verbatim copy of what arrived on
  /// the webhook. Preserved for audit / future field harvesting.
  rawProfile          Json?   @map("raw_profile")
  /// IMMUTABLE — first-seen phone, snapshot of `phone` at create time.
  /// Used for dedupe forensics if the canonical `phone` is later
  /// re-normalised (rare, e.g. a tenant default-dial-code correction).
  originalPhone       String  @map("original_phone")
  /// IMMUTABLE — first-seen display name. Preserves what the provider
  /// initially sent so an agent's `displayName` cleanup never
  /// destroys the original identity.
  originalDisplayName String? @map("original_display_name")

  firstSeenAt DateTime @default(now()) @map("first_seen_at") @db.Timestamptz(6)
  lastSeenAt  DateTime @default(now()) @map("last_seen_at") @db.Timestamptz(6)

  /// Denormalised flags consumed by the inbound router (B3) and the
  /// admin UI. Kept in sync by triggers on captains / leads.
  isCaptain   Boolean @default(false) @map("is_captain")
  hasOpenLead Boolean @default(false) @map("has_open_lead")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  conversations WhatsAppConversation[]
  leads         Lead[]
  reviews       WhatsAppConversationReview[]
  /// Phase D2 — D2.1: every duplicate-decision audit row that was
  /// evaluated for THIS contact. Empty until D2.3 starts writing.
  duplicateDecisions DuplicateDecisionLog[]

  @@unique([tenantId, phone])
  @@index([tenantId, lastSeenAt])
  @@index([tenantId, isCaptain])
  @@index([tenantId, hasOpenLead])
  @@map("contacts")
}

/// Phase C — C10B-1: WhatsAppConversationReview — duplicate / captain
/// review queue.
///
/// Created by the inbound router (B3) when an inbound message can't
/// be routed straight into the normal sales funnel:
///   - 'captain_active'           — the contact is already an active
///                                  captain; never auto-create a sales lead.
///   - 'duplicate_lead'            — multiple non-terminal leads match
///                                  the contact's phone.
///   - 'unmatched_after_routing'   — no rule matched + no eligible
///                                  agent found for round-robin.
///
/// One row per conversation (UNIQUE on conversationId): a queued
/// conversation cannot enter the queue twice. `resolvedAt` flips the
/// row out of the active queue without deleting it — full audit trail
/// preserved.
model WhatsAppConversationReview {
  id             String               @id @default(uuid()) @db.Uuid
  tenantId       String               @map("tenant_id") @db.Uuid
  tenant         Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  conversationId String               @unique @map("conversation_id") @db.Uuid
  conversation   WhatsAppConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  contactId      String               @map("contact_id") @db.Uuid
  contact        Contact              @relation(fields: [contactId], references: [id], onDelete: Cascade)

  /// 'captain_active' | 'duplicate_lead' | 'unmatched_after_routing'
  reason             String
  /// Populated when reason='duplicate_lead'. Lead UUIDs that share
  /// the contact's phone and are NOT in a terminal stage. The
  /// reviewer picks one, dismisses, or creates a new lead.
  candidateLeadIds   String[] @map("candidate_lead_ids") @db.Uuid
  /// Populated when reason='captain_active'.
  candidateCaptainId String?  @map("candidate_captain_id") @db.Uuid

  /// Snapshot of the last 2 inbound message bodies at the moment the
  /// review row was created. Gives reviewers context without paging
  /// through the conversation. Stored as a small JSON array of
  /// `{ text, createdAt }` rather than a relation so the snapshot
  /// remains stable even if future messages arrive.
  contextSnapshot Json? @map("context_snapshot")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  /// Resolution metadata — written by the resolveReview write path (B4).
  resolvedAt   DateTime? @map("resolved_at") @db.Timestamptz(6)
  resolvedById String?   @map("resolved_by_id") @db.Uuid
  /// 'linked_to_lead' | 'linked_to_captain' | 'new_lead' | 'dismissed'
  resolution   String?

  @@index([tenantId, resolvedAt])
  @@index([tenantId, reason])
  @@map("whatsapp_conversation_reviews")
}

/// Phase D2 — D2.1: append-only audit log of every duplicate-detection
/// decision the system makes (auto or manual).
///
/// One row per evaluation. Captures the input (matched leads + matched
/// captain), the rule that fired, the outcome (`decision`), and links
/// to whatever the decision produced (a new Lead, a Review row).
/// Reviewers and Ops use this log to:
///   - audit reactivation policy ("why was this auto-reactivated?"),
///   - sanity-check rule changes ("after we lowered the cool-off,
///     how many leads got reactivated?"),
///   - investigate compliance edge cases.
///
/// D2.1 ONLY ships the storage. No service writes to this table yet —
/// `DuplicateDecisionService` lands in D2.2 (behind LEAD_ATTEMPTS_V2
/// flag) and starts populating rows in D2.3.
///
/// Tenant-scoped via FORCE'd RLS, same as the rest of the CRM.
model DuplicateDecisionLog {
  id        String  @id @default(uuid()) @db.Uuid
  tenantId  String  @map("tenant_id") @db.Uuid
  tenant    Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  /// Identity anchor for the decision. Nullable only for the rare
  /// case where the trigger fired before a Contact existed (e.g. a
  /// raw Meta payload lacking a phone we could normalise). In that
  /// case the row still records `phone` so an admin can reconstruct.
  contactId String?  @map("contact_id") @db.Uuid
  contact   Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)

  /// E.164 phone the decision was evaluated against. Always present
  /// even when `contactId` is NULL.
  phone     String

  /// Where the decision came from.
  /// 'manual' | 'csv' | 'meta' | 'whatsapp_inbound' | 'review_resolve_new_lead' | 'review_resolve_new_attempt'
  trigger   String

  /// Inputs the rule engine considered.
  matchedLeadIds   String[] @map("matched_lead_ids") @db.Uuid
  matchedCaptainId String?  @map("matched_captain_id") @db.Uuid

  /// Which rule fired. Stable string codes — easier to dashboard than
  /// an enum that has to migrate every time we add a rule.
  /// 'create_first_attempt'
  ///   | 'reactivate_lost_aged_out'
  ///   | 'reactivate_no_answer_aged_out'
  ///   | 'route_to_review_active_captain'
  ///   | 'route_to_review_open_lead'
  ///   | 'route_to_review_won'
  ///   | 'reject_existing_open'
  ///   | 'manual_override'
  ruleApplied String  @map("rule_applied")

  /// What the system did about it.
  /// 'created_new_attempt' | 'queued_review' | 'linked_to_existing' | 'rejected'
  decision    String

  /// Engine confidence ('high' | 'medium' | 'low'). Low routes to
  /// review queue regardless of rule match — a guard against false
  /// positives in fuzzy phone-normalisation cases.
  confidence  String  @default("high")

  /// Actor user ID — populated for manual / review-resolve decisions,
  /// NULL for automatic ingest (CSV / Meta / inbound) where the
  /// system itself is the actor.
  actorUserId String? @map("actor_user_id") @db.Uuid
  actor       User?   @relation("DuplicateDecisionActor", fields: [actorUserId], references: [id])

  /// Outputs of the decision (when applicable).
  resultLeadId   String? @map("result_lead_id") @db.Uuid
  resultLead     Lead?   @relation("DuplicateDecisionResultLead", fields: [resultLeadId], references: [id], onDelete: SetNull)
  resultReviewId String? @map("result_review_id") @db.Uuid

  /// Free-form payload for any extra context (rule input snapshots,
  /// timing details, age-of-previous-lead in days, …). Never holds
  /// raw provider metadata.
  payload   Json?

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  // Index for the per-contact "show every duplicate decision for
  // this person" view on the lead detail page (D2.5).
  @@index([tenantId, contactId, createdAt])
  // Index for the Ops "auto-decisions" dashboard tab (D2.5) which
  // groups by `decision` over a time window.
  @@index([tenantId, decision, createdAt])
  @@map("duplicate_decision_log")
}

/// WhatsAppAccount — per-tenant configuration for one provider connection.
///
/// MVP supports `meta_cloud` (WhatsApp Business Platform — Cloud API). The
/// `accessToken` is stored as-is for now; production deployments must wrap
/// the column with field-level encryption. The token is NEVER returned to
/// clients — services that read the column live behind module-internal
/// helpers and the controller never selects it.
///
/// `verifyToken` is the value Meta sends on the GET handshake when first
/// registering the webhook (`hub.verify_token`); kept per-account so two
/// tenants in the same deployment can wire up independent webhooks.
/// `phoneNumberId` is Meta's identifier in the Cloud API URL path
/// (`/v20.0/{phone-number-id}/messages`) and inside inbound webhook
/// `value.metadata.phone_number_id` — used to route inbound messages to
/// the right account/tenant.
/// `appSecret` enables HMAC-SHA256 signature verification of inbound
/// webhooks (`x-hub-signature-256`); optional in dev, recommended in prod.
model WhatsAppAccount {
  id            String  @id @default(uuid()) @db.Uuid
  tenantId      String  @map("tenant_id") @db.Uuid
  tenant        Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  /// Friendly label shown in admin lists (e.g. "Egypt — Uber sales line").
  displayName   String  @map("display_name")
  /// E.164 phone number this account sends from (display number).
  phoneNumber   String  @map("phone_number")
  /// Meta's phone-number-id used in URL paths + webhook routing.
  phoneNumberId String  @map("phone_number_id")
  /// `meta_cloud` for now; extensible (e.g. `360dialog`, `gupshup`).
  provider      String
  /// Long-lived access token. Sensitive — never returned to clients.
  accessToken   String  @map("access_token")
  /// Meta App secret for HMAC signature verification (optional).
  appSecret     String? @map("app_secret")
  /// Webhook GET-handshake verify token. Unique-per-tenant.
  verifyToken   String  @map("verify_token")
  isActive      Boolean @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  messages      WhatsAppMessage[]
  conversations WhatsAppConversation[]
  templates     WhatsAppTemplate[]

  // Phone number is unique per tenant; phoneNumberId is unique globally
  // (Meta-assigned), so we add a stable lookup index for inbound routing.
  @@unique([tenantId, phoneNumber])
  @@unique([phoneNumberId])
  @@index([tenantId, isActive])
  @@map("whatsapp_accounts")
}

/// WhatsAppMessage — append-only traffic log (inbound + outbound).
///
/// Direction:
///   `inbound`   the OTHER party sent us a message (persisted by the webhook).
///   `outbound`  we sent a message via the provider (persisted by sendText).
///
/// `phone` is always the OTHER party's E.164 number; for inbound it's the
/// customer, for outbound the recipient. The account's own number lives on
/// the related WhatsAppAccount row, not duplicated here.
///
/// `providerMessageId` is the id Meta assigns. It's globally unique on
/// Meta's side, but we constrain uniqueness per-tenant so duplicate
/// webhook deliveries are idempotent (P2002 → no-op).
model WhatsAppMessage {
  id        String          @id @default(uuid()) @db.Uuid
  tenantId  String          @map("tenant_id") @db.Uuid
  tenant    Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  accountId String          @map("account_id") @db.Uuid
  account   WhatsAppAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  /// Conversation this message belongs to (C22). Required after migration —
  /// every inbound + outbound message attaches to exactly one conversation
  /// keyed on (tenantId, accountId, phone).
  conversationId String               @map("conversation_id") @db.Uuid
  conversation   WhatsAppConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  /// Other party's E.164 phone number.
  phone             String
  /// Plain text body. For media messages this is the optional caption
  /// (empty string when none). For template messages it's the rendered
  /// template body — convenient for the inbox preview without joining
  /// `whatsapp_templates` and resolving variables.
  text              String
  /// `inbound` | `outbound`.
  direction         String
  /// P2-12 — message kind: 'text' | 'template' | 'image' | 'document'.
  /// Existing rows backfill to 'text'; the column has a default so old
  /// service code paths keep working unchanged.
  messageType       String  @default("text") @map("message_type")
  /// P2-12 — operator-hosted media URL (S3, signed-URL, etc). Set only
  /// when messageType ∈ {'image', 'document'}. NULL for text +
  /// template messages.
  mediaUrl          String? @map("media_url")
  /// P2-12 — optional MIME type echoed back from the provider so the
  /// inbox can render an icon hint. NULL for text + template.
  mediaMimeType     String? @map("media_mime_type")
  /// P2-12 — Meta-approved template name + BCP-47 language code, set
  /// only when messageType = 'template'.
  templateName      String? @map("template_name")
  templateLanguage  String? @map("template_language")
  /// Meta's message id (whatsapp_business_api id). Optional for queued
  /// outbound messages where we haven't received a provider id yet.
  providerMessageId String? @map("provider_message_id")
  /// Outbound lifecycle: `queued` → `sent` → `delivered` → `read` | `failed`.
  /// Inbound rows always start at `received` (terminal for inbound).
  status            String  @default("received")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  // Idempotent webhook ingestion: same providerMessageId in the same
  // tenant is rejected by the unique constraint.
  @@unique([tenantId, providerMessageId])
  @@index([tenantId, phone, createdAt])
  @@index([tenantId, direction])
  @@index([accountId, createdAt])
  @@index([conversationId, createdAt])
  @@map("whatsapp_messages")
}

/// WhatsAppConversation — one threaded conversation per (account × other-party-phone).
///
/// Messages always belong to exactly one conversation. The "open"/"closed"
/// status acts as a soft-archive flag: a closed conversation lets the
/// next inbound message start a fresh thread, so a partial-unique index
/// `(tenant_id, account_id, phone) WHERE status = 'open'` enforces the
/// "one open conversation per phone per account" rule.
///
/// `lastMessageAt` + `lastMessageText` are denormalised summaries kept in
/// sync at every message-insert. The inbox UI (later chunks) renders the
/// list against these columns without joining the messages table.
model WhatsAppConversation {
  id        String          @id @default(uuid()) @db.Uuid
  tenantId  String          @map("tenant_id") @db.Uuid
  tenant    Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  accountId String          @map("account_id") @db.Uuid
  account   WhatsAppAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  /// Other party's E.164 phone number.
  phone           String
  /// `open` | `closed`. The partial unique index below enforces "one
  /// open conversation per (tenantId, accountId, phone)" — a closed
  /// thread doesn't block a new one.
  status          String    @default("open")
  /// Most recent message timestamp + text body, denormalised for cheap
  /// inbox-list rendering. Kept in sync at message-insert time.
  lastMessageAt   DateTime  @default(now()) @map("last_message_at") @db.Timestamptz(6)
  lastMessageText String    @default("") @map("last_message_text")
  /// P2-12 — timestamp of the most recent INBOUND message in this
  /// thread, used to enforce Meta's 24-hour customer-service window.
  /// NULL when the contact has never replied: in that case the agent
  /// may only initiate the conversation via an approved template.
  lastInboundAt   DateTime? @map("last_inbound_at") @db.Timestamptz(6)

  /// C25 — optional link to a Lead in the same tenant. Set explicitly via
  /// the link-lead endpoint, or auto-linked on read when exactly one
  /// tenant-scoped lead matches `phone`. Multiple-match leads are not
  /// auto-linked (admin must pick). FK is ON DELETE SET NULL so deleting
  /// a lead does not cascade-delete the conversation history.
  leadId String? @map("lead_id") @db.Uuid
  lead   Lead?   @relation("ConversationLead", fields: [leadId], references: [id], onDelete: SetNull)

  /// Phase C — C10B-1: stable contact identity. Required after the B2
  /// migration step backfills every existing conversation; nullable
  /// for now so the schema change is non-breaking. Inbound flow (B3)
  /// will create or match a Contact per (tenantId, phone) on every
  /// webhook hit.
  contactId String?  @map("contact_id") @db.Uuid
  contact   Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)

  /// Phase C — C10B-1: ownership chain. All four columns are
  /// denormalised at routing/handover time so the scope resolver can
  /// filter conversations directly without joining through the lead
  /// (critical for unlinked-but-assigned conversations). Set by the
  /// inbound router (B3) and the manual handover endpoint; rewritten
  /// when a lead is reassigned (per the open-question decision in
  /// the C10B plan).
  assignedToId     String?   @map("assigned_to_id") @db.Uuid
  assignedTo       User?     @relation("WhatsAppConversationAssignee", fields: [assignedToId], references: [id], onDelete: SetNull)
  teamId           String?   @map("team_id") @db.Uuid
  team             Team?     @relation(fields: [teamId], references: [id], onDelete: SetNull)
  companyId        String?   @map("company_id") @db.Uuid
  company          Company?  @relation(fields: [companyId], references: [id], onDelete: SetNull)
  countryId        String?   @map("country_id") @db.Uuid
  country          Country?  @relation(fields: [countryId], references: [id], onDelete: SetNull)
  /// Provenance for the current ownership row. Lets audit + UI tell
  /// "auto-routed" from "manually handed over" from "agent self-claim
  /// on outbound" from "migrated by backfill". Values:
  ///   'inbound_route'    — assigned by the inbound router (B3)
  ///   'manual_handover'  — handover endpoint (B4)
  ///   'outbound_self'    — agent replied to an unowned conversation
  ///   'migrated'         — written by the C10B-2 backfill script
  ///   'lead_propagation' — re-denormalised when the linked lead was
  ///                        reassigned
  assignmentSource String?   @map("assignment_source")
  assignedAt       DateTime? @map("assigned_at") @db.Timestamptz(6)

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  messages        WhatsAppMessage[]
  /// Phase C — C10B-1: review queue rows (1:0..1) for this conversation.
  review          WhatsAppConversationReview?
  /// Phase C — C10B-1: leads that point to this conversation as their
  /// primary chat surface ("open WhatsApp from Lead"). 0..N because
  /// the same conversation may be the primary surface for multiple
  /// leads across re-entries.
  primaryForLeads Lead[]                      @relation("LeadPrimaryConversation")

  @@index([tenantId, accountId, lastMessageAt])
  @@index([tenantId, status, lastMessageAt])
  @@index([tenantId, leadId])
  @@index([tenantId, lastInboundAt])
  /// Phase C — C10B-1: scope-resolver hot paths. Each scope value
  /// hits one of these indexes directly.
  @@index([tenantId, assignedToId, status])
  @@index([tenantId, teamId, status])
  @@index([tenantId, companyId, status])
  @@index([tenantId, countryId, status])
  @@index([tenantId, contactId])
  @@map("whatsapp_conversations")
}

/// WhatsAppTemplate (P2-12) — record of a Meta-approved template the
/// tenant uses to start a conversation outside the 24-hour
/// customer-service window. We do NOT submit / approve templates from
/// the CRM (operators do that in Meta's WABA console); instead the
/// admin records the approved template metadata so agents can pick
/// it from a dropdown when sending.
///
/// `bodyText` is the rendered text WITH `{{1}}` / `{{2}}` placeholders
/// — clients fill them in via the variables array on send. The
/// CRM tracks `status` so an admin can mark a template "rejected" or
/// "paused" and it disappears from the picker.
model WhatsAppTemplate {
  id        String          @id @default(uuid()) @db.Uuid
  tenantId  String          @map("tenant_id") @db.Uuid
  tenant    Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  accountId String          @map("account_id") @db.Uuid
  account   WhatsAppAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  /// Meta-approved template name (e.g. "appointment_reminder").
  name          String
  /// BCP-47 language code (e.g. "en", "ar", "en_US").
  language      String
  /// Meta category — determines Meta's pricing / latency profile.
  /// One of: `marketing` | `utility` | `authentication`.
  category      String
  /// Body template with positional placeholders `{{1}}`, `{{2}}`, ...
  bodyText      String @map("body_text")
  /// Number of placeholder variables in `bodyText`. Pre-computed at
  /// upsert time so the picker can validate the variable count
  /// without re-parsing the template body on every render.
  variableCount Int    @default(0) @map("variable_count")
  /// Lifecycle in the CRM: `approved` (default — agent can use it),
  /// `paused` (admin disabled), `rejected` (Meta rejected).
  status        String @default("approved")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@unique([accountId, name, language])
  @@index([tenantId, status])
  @@map("whatsapp_templates")
}

/// WhatsAppRoute — denormalised routing projection of WhatsAppAccount.
///
/// Created in 0009; declared here so Prisma stops trying to drop it on
/// every subsequent migration. The table is intentionally NOT
/// row-level-security'd and carries only routing fields (no access
/// token). A trigger on `whatsapp_accounts` keeps it in sync; the
/// application reads it directly via $queryRaw for the public webhook's
/// pre-tenant lookup.
model WhatsAppRoute {
  /// PK is account_id (one route per account).
  accountId     String  @id @map("account_id") @db.Uuid
  phoneNumberId String  @unique @map("phone_number_id")
  verifyToken   String  @map("verify_token")
  tenantId      String  @map("tenant_id") @db.Uuid
  provider      String
  appSecret     String? @map("app_secret")
  isActive      Boolean @map("is_active")

  @@index([verifyToken])
  @@map("whatsapp_routes")
}

/// BonusRule (C32) — admin-managed bonus configuration.
/// Scope: Company × Country, optionally narrowed by Team and/or Role.
/// Type: one of first_trip / activation / trip_milestone / conversion_rate / manual.
/// `trigger` is a free-text description (e.g. "5 first trips in week").
/// `amount` is in tenant default currency (Decimal, 12 / 2). Payout
/// engine + bonus-period accruals land in a later chunk; for the MVP
/// we only manage rules.
model BonusRule {
  id       String @id @default(uuid()) @db.Uuid
  tenantId String @map("tenant_id") @db.Uuid
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  companyId String  @map("company_id") @db.Uuid
  company   Company @relation(fields: [companyId], references: [id], onDelete: Restrict)
  countryId String  @map("country_id") @db.Uuid
  country   Country @relation(fields: [countryId], references: [id], onDelete: Restrict)
  teamId    String? @map("team_id") @db.Uuid
  team      Team?   @relation(fields: [teamId], references: [id], onDelete: SetNull)
  roleId    String? @map("role_id") @db.Uuid
  role      Role?   @relation(fields: [roleId], references: [id], onDelete: SetNull)

  bonusType String  @map("bonus_type")
  trigger   String
  amount    Decimal @db.Decimal(12, 2)
  isActive  Boolean @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  accruals BonusAccrual[]

  @@index([tenantId, isActive])
  @@index([tenantId, companyId, countryId])
  @@map("bonus_rules")
}

/// BonusAccrual (P2-03) — one row per fired bonus rule.
///
/// Created by `BonusEngine.onActivation(captain)` when a lead converts
/// to an active captain. Future trigger kinds (`first_trip`,
/// `trip_milestone`) layer on without schema changes — `triggerKind`
/// is a string. `recipientUserId` is the agent who earned the bonus
/// (the captain's lead's assignee at activation time). `status` flows
/// through `pending → paid` (or `void` via admin action) — payout
/// pipeline ships in P2-13.
model BonusAccrual {
  id       String @id @default(uuid()) @db.Uuid
  tenantId String @map("tenant_id") @db.Uuid
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  bonusRuleId String    @map("bonus_rule_id") @db.Uuid
  bonusRule   BonusRule @relation(fields: [bonusRuleId], references: [id], onDelete: Restrict)

  recipientUserId String @map("recipient_user_id") @db.Uuid
  recipient       User   @relation("BonusAccrualRecipient", fields: [recipientUserId], references: [id], onDelete: Restrict)

  captainId String?  @map("captain_id") @db.Uuid
  captain   Captain? @relation(fields: [captainId], references: [id], onDelete: SetNull)

  triggerKind String  @map("trigger_kind")
  amount      Decimal @db.Decimal(12, 2)
  status      String  @default("pending")
  payload     Json?

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  // Idempotency: a rule fires once per (rule, captain, trigger).
  @@unique([bonusRuleId, captainId, triggerKind])
  // "all my pending accruals, newest first" + admin filter by status.
  @@index([tenantId, recipientUserId, status, createdAt])
  @@index([tenantId, status, createdAt])
  @@map("bonus_accruals")
}

/// Notification (P2-02) — in-app inbox for time-sensitive events.
///
/// Kinds (loose enum, kept as string for forward-compat):
///   - sla.breach            — your assigned lead breached SLA.
///   - followup.due          — your follow-up just hit dueAt.
///   - followup.assigned     — a follow-up was scheduled for you.
///   - whatsapp.handover     — a conversation was handed off to you.
///
/// Payload carries the relevant entity ids; the inbox UI deep-links.
/// `readAt` flips when the recipient marks it read; null = unread.
model Notification {
  id       String @id @default(uuid()) @db.Uuid
  tenantId String @map("tenant_id") @db.Uuid
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  recipientUserId String @map("recipient_user_id") @db.Uuid
  recipient       User   @relation(fields: [recipientUserId], references: [id], onDelete: Cascade)

  kind    String
  title   String
  body    String?
  payload Json?
  readAt  DateTime? @map("read_at") @db.Timestamptz(6)

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  // "My inbox, unread first then newest first" — covering index.
  @@index([tenantId, recipientUserId, readAt, createdAt])
  @@map("notifications")
}

/// AuditEvent (C40) — non-lead-scoped admin actions.
///
/// Lead-scoped events (note, stage_change, assignment, sla_breach,
/// whatsapp_handover) live on `lead_activities` already. This table
/// captures the rest: bonus rule changes, competition changes,
/// follow-up create / complete, etc. The unified /audit endpoint
/// streams both tables in a single normalized view sorted desc by
/// timestamp.
model AuditEvent {
  id       String @id @default(uuid()) @db.Uuid
  tenantId String @map("tenant_id") @db.Uuid
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  /// Stable action verb, e.g. "bonus.create", "competition.status_change".
  action      String
  entityType  String? @map("entity_type")
  entityId    String? @map("entity_id") @db.Uuid
  payload     Json?
  actorUserId String? @map("actor_user_id") @db.Uuid
  actor       User?   @relation(fields: [actorUserId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([tenantId, createdAt])
  @@index([tenantId, action, createdAt])
  @@map("audit_events")
}

/// LeadFollowUp (C36) — a scheduled future action on a lead.
///
/// Type is one of: call / whatsapp / visit / other. `dueAt` is when
/// it should happen. `assignedToId` is the agent who owns the
/// follow-up (defaults to the lead's current assignee, but can be
/// overridden at create time). `completedAt` flips when the agent
/// marks it done — overdue = !completed && dueAt < now.
model LeadFollowUp {
  id       String @id @default(uuid()) @db.Uuid
  tenantId String @map("tenant_id") @db.Uuid
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  leadId   String @map("lead_id") @db.Uuid
  lead     Lead   @relation(fields: [leadId], references: [id], onDelete: Cascade)

  actionType   String    @map("action_type")
  dueAt        DateTime  @map("due_at") @db.Timestamptz(6)
  note         String?
  completedAt  DateTime? @map("completed_at") @db.Timestamptz(6)
  /// Phase A — A1: when set + > now, the row is hidden from
  /// "overdue" / "due-today" counters until snoozedUntil passes.
  /// Cleared on completion.
  snoozedUntil DateTime? @map("snoozed_until") @db.Timestamptz(6)
  /// Phase C — C10B-1: provenance — same enum-like values as
  /// LeadActivity.actionSource. Lets reports break down "follow-ups
  /// scheduled from chat" vs "from the lead page".
  actionSource String    @default("lead") @map("action_source")

  assignedToId String? @map("assigned_to_id") @db.Uuid
  assignedTo   User?   @relation("LeadFollowUpAssignee", fields: [assignedToId], references: [id], onDelete: SetNull)
  createdById  String? @map("created_by_id") @db.Uuid
  createdBy    User?   @relation("LeadFollowUpCreator", fields: [createdById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([tenantId, leadId, dueAt])
  // Hot path: "my open follow-ups, soonest first" + the overdue scan.
  @@index([tenantId, assignedToId, completedAt, dueAt])
  @@map("lead_followups")
}

/// LostReason (Phase A — A1) — per-tenant configurable list of
/// rejection reasons. Required when a lead is moved to a stage with
/// `terminalKind = 'lost'`. Multi-language at the row level
/// (labelEn / labelAr); future locales add columns without a
/// migration of existing rows.
///
/// `code` is a stable machine identifier (e.g. 'no_vehicle');
/// labels are display-only and may be edited freely. The seed
/// installs 7 canonical reasons per tenant; admins can add /
/// rename / reorder / deactivate via /admin/lost-reasons. The
/// 'other' code is protected from deactivation as a fallback.
model LostReason {
  id           String   @id @default(uuid()) @db.Uuid
  tenantId     String   @map("tenant_id") @db.Uuid
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  code         String
  labelEn      String   @map("label_en")
  labelAr      String   @map("label_ar")
  isActive     Boolean  @default(true) @map("is_active")
  displayOrder Int      @default(100) @map("display_order")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  /// Leads currently lost for this reason. ON DELETE RESTRICT on the
  /// FK forbids deleting an in-use reason — admin must deactivate.
  leads Lead[]

  @@unique([tenantId, code])
  @@index([tenantId, isActive, displayOrder])
  @@map("lost_reasons")
}

/// Competition (C33) — admin-managed agent / team contest definition.
/// `metric` is the leaderboard yardstick: leads_created / activations
/// / first_trips / conversion_rate. `status` is draft / active / closed.
/// Leaderboard computation is best-effort against the existing data
/// (leads + lead_activities); a richer materialised view ships later.
model Competition {
  id       String @id @default(uuid()) @db.Uuid
  tenantId String @map("tenant_id") @db.Uuid
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  name      String
  companyId String?  @map("company_id") @db.Uuid
  company   Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)
  countryId String?  @map("country_id") @db.Uuid
  country   Country? @relation(fields: [countryId], references: [id], onDelete: SetNull)
  teamId    String?  @map("team_id") @db.Uuid
  team      Team?    @relation(fields: [teamId], references: [id], onDelete: SetNull)

  startDate DateTime @map("start_date") @db.Timestamptz(6)
  endDate   DateTime @map("end_date") @db.Timestamptz(6)
  metric    String
  reward    String
  status    String   @default("draft")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([tenantId, status, startDate])
  @@map("competitions")
}

/// MetaLeadSource (P2-06) — routing config for Meta Lead Ads webhooks.
///
/// Each Facebook Page (or Instagram form) the tenant runs ads on
/// registers one row here. The public `/webhooks/meta/leadgen`
/// endpoint is cross-tenant: it looks the row up by `pageId`
/// (POST inbound) or `verifyToken` (GET handshake) and uses the
/// matching `tenantId` to write the lead. Sensitive verify/secret
/// values are stored here (NEVER returned to admin clients in full).
///
/// `fieldMapping` is a JSON object that maps incoming Meta form
/// field names → CRM lead fields. Example:
///   { "full_name": "name", "phone_number": "phone", "email": "email" }
/// When a payload arrives, the service walks the mapping and applies
/// the values to a `CreateLeadDto`. A `name` and `phone` are
/// required to ingest; missing → drop with an audit row.
model MetaLeadSource {
  id       String @id @default(uuid()) @db.Uuid
  tenantId String @map("tenant_id") @db.Uuid
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  /// Friendly label shown in admin (e.g. "Cairo — Uber driver page").
  displayName   String  @map("display_name")
  /// Meta Page id receiving the webhook delivery.
  pageId        String  @map("page_id")
  /// Optional form id (when the same page runs multiple lead forms).
  formId        String? @map("form_id")
  /// GET handshake verify token (unique-per-tenant by convention).
  verifyToken   String  @map("verify_token")
  /// Meta App secret for HMAC signature verification.
  appSecret     String? @map("app_secret")
  /// Lead source value written on every ingested lead. Defaults to "meta".
  defaultSource String  @default("meta") @map("default_source")
  /// Field mapping (Meta form field name → CRM lead field). JSON.
  fieldMapping  Json    @map("field_mapping")
  isActive      Boolean @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@unique([tenantId, pageId, formId])
  @@index([tenantId, isActive])
  @@map("meta_lead_sources")
}

/// TenantSettings (P2-08) — one-per-tenant configuration row.
///
/// 1:1 with Tenant via `tenant_id` as the primary key. Carries
/// runtime knobs that previously lived in env vars or were
/// hardcoded:
///
///   - `timezone` (IANA, e.g. "Africa/Cairo") drives day-boundary
///     calculations for `listDueToday` so an admin in Cairo and an
///     admin in Casablanca see the right "today" without shifting
///     the server clock.
///
///   - `slaMinutes` is the response-SLA window. Replaces the
///     `LEAD_SLA_MINUTES` env var; the env var becomes the
///     fallback used only when the row is missing.
///
///   - `defaultDialCode` (e.g. "+20", "+966") is prepended to bare
///     local-format phone numbers in lead-creating flows so an
///     admin can paste "01001234567" and get "+201001234567".
///     The strict `normalizeE164` helper still rejects malformed
///     input — the prefix is only applied when the input lacks a
///     country code.
///
/// Tenant-scoped via FORCE'd RLS, same as the rest of the CRM.
model TenantSettings {
  tenantId          String   @id @map("tenant_id") @db.Uuid
  tenant            Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  timezone          String   @default("Africa/Cairo")
  slaMinutes        Int      @default(60) @map("sla_minutes")
  defaultDialCode   String   @default("+20") @map("default_dial_code")
  /// PL-3 — legacy `{source, assigneeUserId}` JSONB. Phase 1A migrates
  /// these into the relational `distribution_rules` table; the column is
  /// kept for one release as a rollback safety net but services no
  /// longer read it. Drop in a future migration.
  distributionRules Json     @default("[]") @map("distribution_rules")
  /// Phase 1A — fallback strategy when DistributionService.route() finds
  /// no matching rule. One of: 'capacity' | 'round_robin' | 'weighted'.
  /// `specific_user` is intentionally excluded here (it requires a per-rule
  /// target). Defaults to 'capacity' so existing tenants behave identically
  /// to today's implementation.
  defaultStrategy   String   @default("capacity") @map("default_strategy")

  /// Phase D2 — D2.1: tenant-configurable duplicate / reactivation
  /// rules. NULL means "use code defaults" (D2.2 introduces the
  /// safe defaults below). The expected shape is:
  /// {
  ///   "reactivateLostAfterDays":           30,
  ///   "reactivateNoAnswerAfterDays":       7,
  ///   "reactivateNoAnswerLostReasonCodes": ["no_answer", "no_response"],
  ///   "captainBehavior":                   "always_review",
  ///   "wonBehavior":                       "always_review",
  ///   "ownershipOnReactivation":           "route_engine",
  ///   "crossPipelineMatch":                false
  /// }
  /// D2.1 only adds the column; D2.2 introduces the typed Zod
  /// schema + service that reads / writes it. Older rows stay
  /// NULL on UPDATE; no behavior change.
  duplicateRules    Json?    @map("duplicate_rules")

  /// Phase D3 — D3.5: per-tenant SLA escalation policy (JSONB seam).
  /// Shape:
  /// {
  ///   "thresholds": {
  ///     "t75":  { "action": "notify_only" },
  ///     "t100": { "action": "notify_and_tag" },
  ///     "t150": {
  ///       "action": "rotate_or_review",
  ///       "rotateOnFirst": true,
  ///       "reviewOnRepeatWithinHours": 24
  ///     },
  ///     "t200": { "action": "raise_review" }
  ///   },
  ///   "defaultHandoverMode": "full"
  /// }
  /// NULL = use the locked product defaults (DEFAULT_ESCALATION_RULES
  /// in escalation-rules.dto.ts). No admin UI ships in D3.5 — the
  /// column is service-only until D3.7 polish adds the editor panel.
  escalationRules   Json?    @map("escalation_rules")

  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("tenant_settings")
}

/// Phase 1A — DistributionRule.
///
/// One row per routing rule. NULL on a match column means wildcard.
/// The DistributionService picks the highest-priority active rule whose
/// non-NULL conditions all match the lead context (lower priority = higher
/// precedence). Ties are broken by `createdAt` ascending.
///
/// Strategies:
///   - `specific_user` — route directly to `targetUserId` if eligible.
///   - `round_robin`   — turn-based; oldest `users.lastAssignedAt` wins.
///   - `weighted`      — probabilistic by `agent_capacities.weight`.
///   - `capacity`      — lowest active-lead count among eligible.
///
/// `targetTeamId` (when set) restricts the candidate pool to that team
/// regardless of strategy.
model DistributionRule {
  id       String  @id @default(uuid()) @db.Uuid
  tenantId String  @map("tenant_id") @db.Uuid
  tenant   Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name     String
  isActive Boolean @default(true) @map("is_active")
  priority Int     @default(100)

  /// Match conditions (NULL = any). All non-NULL fields must match.
  source       String?
  companyId    String?  @map("company_id") @db.Uuid
  company      Company? @relation(fields: [companyId], references: [id], onDelete: Cascade)
  countryId    String?  @map("country_id") @db.Uuid
  country      Country? @relation(fields: [countryId], references: [id], onDelete: Cascade)
  targetTeamId String?  @map("target_team_id") @db.Uuid
  targetTeam   Team?    @relation(fields: [targetTeamId], references: [id], onDelete: SetNull)

  /// Strategy + per-strategy target.
  strategy     String
  targetUserId String? @map("target_user_id") @db.Uuid
  targetUser   User?   @relation("DistributionRuleTargetUser", fields: [targetUserId], references: [id], onDelete: SetNull)

  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdById String?  @map("created_by_id") @db.Uuid
  createdBy   User?    @relation("DistributionRuleAuthor", fields: [createdById], references: [id], onDelete: SetNull)

  routingLogs LeadRoutingLog[]

  @@index([tenantId, priority, isActive])
  @@index([tenantId, source])
  @@map("distribution_rules")
}

/// Phase 1A — AgentCapacity.
///
/// Optional per-user configuration consumed by the candidate filter
/// pipeline + the weighted strategy. A user without a row uses the
/// defaults synthesised in `CapacitiesService.getEffective`:
///   { maxActiveLeads: null, weight: 1, isAvailable: true,
///     outOfOfficeUntil: null, workingHours: null }.
///
/// `workingHours` shape (when set):
///   { mon: { start: "09:00", end: "18:00" }, tue: { ... }, ... }
/// Times are in the tenant's IANA timezone (`tenant_settings.timezone`).
model AgentCapacity {
  userId           String    @id @map("user_id") @db.Uuid
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenantId         String    @map("tenant_id") @db.Uuid
  tenant           Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  maxActiveLeads   Int?      @map("max_active_leads")
  weight           Int       @default(1)
  isAvailable      Boolean   @default(true) @map("is_available")
  outOfOfficeUntil DateTime? @map("out_of_office_until") @db.Timestamptz(6)
  workingHours     Json?     @map("working_hours")
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([tenantId, isAvailable])
  @@map("agent_capacities")
}

/// Phase 1A — LeadRoutingLog.
///
/// Append-only audit row written for every DistributionService.route()
/// call, including no-eligible-agent outcomes (which are precisely the
/// cases ops needs to see). `excludedReasons` is keyed by user id so
/// the UI can render "candidate Bob excluded — out_of_office".
model LeadRoutingLog {
  id              String            @id @default(uuid()) @db.Uuid
  tenantId        String            @map("tenant_id") @db.Uuid
  tenant          Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  leadId          String            @map("lead_id") @db.Uuid
  lead            Lead              @relation(fields: [leadId], references: [id], onDelete: Cascade)
  ruleId          String?           @map("rule_id") @db.Uuid
  rule            DistributionRule? @relation(fields: [ruleId], references: [id], onDelete: SetNull)
  strategy        String
  chosenUserId    String?           @map("chosen_user_id") @db.Uuid
  chosenUser      User?             @relation("LeadRoutingLogChosen", fields: [chosenUserId], references: [id], onDelete: SetNull)
  candidateCount  Int               @map("candidate_count")
  excludedCount   Int               @map("excluded_count")
  excludedReasons Json              @default("{}") @map("excluded_reasons")
  decidedAt       DateTime          @default(now()) @map("decided_at") @db.Timestamptz(6)
  requestId       String?           @map("request_id")

  @@index([tenantId, leadId, decidedAt(sort: Desc)])
  @@index([tenantId, decidedAt(sort: Desc)])
  @@map("lead_routing_logs")
}
