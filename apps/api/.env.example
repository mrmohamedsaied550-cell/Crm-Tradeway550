# @crm/api — environment template
# Copy this file to .env for local development; never commit .env.

# Runtime
NODE_ENV=development
PORT=3000
LOG_LEVEL=debug

# Database (matches docker-compose.yml)
#
# Connection pool (C28 — production hardening):
#   - `connection_limit` caps the per-process Prisma pool. Default is
#     `num_cpus * 2 + 1`, which is too low for an API under burst load
#     where every withTenant call holds a transactional connection.
#     Recommended starting point: 20 per pod, then size to (DB max_connections /
#     pod count) * 0.8 to leave headroom for migrations / one-off jobs.
#   - `pool_timeout` is the seconds Prisma waits for a free connection
#     before throwing P2024. Default 10s. Bump to 20s if you legitimately
#     have spiky traffic; lower if you'd rather fail fast under starvation
#     so callers can retry.
#   - WhatsApp send/test paths intentionally call Meta OUTSIDE any
#     transaction (see WhatsAppService.sendText) so individual external
#     round-trips do not consume a pool slot for their full duration.
#
# Production example (uncomment and tune for your deploy):
# DATABASE_URL=postgresql://crm_user:CHANGE_ME@db:5432/crm_tradeway?schema=public&connection_limit=20&pool_timeout=20
DATABASE_URL=postgresql://crm_user:crm_dev_pass_2026@localhost:5432/crm_tradeway?schema=public

# Redis
REDIS_URL=redis://localhost:6379

# Auth (placeholders only — real secrets are wired in C9; rotate per environment)
JWT_ACCESS_SECRET=change-me-access
JWT_REFRESH_SECRET=change-me-refresh
JWT_ACCESS_TTL=60m
JWT_REFRESH_TTL=30d
BCRYPT_ROUNDS=12

# Misc
CORS_ALLOWED_ORIGINS=http://localhost:3001
REQUEST_ID_HEADER=x-request-id

# Seed (dev only) — used by `pnpm db:seed` when creating the 5 default users.
# In production this MUST be set to a strong value or the seed must be disabled.
SEED_DEFAULT_PASSWORD=Password@123

# CRM — response SLA window in minutes (clamped 1..1440; default 15).
# Used by SlaService when stamping `sla_due_at` on lead create / activity reset.
LEAD_SLA_MINUTES=15
