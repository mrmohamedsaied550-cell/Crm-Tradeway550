# @crm/web — environment template
# Copy this file to .env.local for local development; never commit .env.local.

# API base URL (server-side and exposed to the browser as NEXT_PUBLIC_*)
NEXT_PUBLIC_API_URL=http://localhost:3000

# Public app URL (used for OAuth callbacks and absolute links)
NEXT_PUBLIC_APP_URL=http://localhost:3001

# Default UI language: ar | en
NEXT_PUBLIC_DEFAULT_LOCALE=ar
